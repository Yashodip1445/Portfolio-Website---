"use client";

import { useState } from "react";
import { motion } from "framer-motion";
import { Mail, Phone, MapPin } from "lucide-react";
import { staggerContainer, staggerItem } from "@/utils/animations";

export default function Contact() {
  const [formData, setFormData] = useState({
    name: "",
    email: "",
    message: "",
  });
  const [isSubmitted, setIsSubmitted] = useState(false);

  const handleChange = (
    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>
  ) => {
    setFormData({
      ...formData,
      [e.target.name]: e.target.value,
    });
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    // Here you would normally send the form data to a backend
    console.log("Form submitted:", formData);
    setIsSubmitted(true);
    setTimeout(() => {
      setFormData({ name: "", email: "", message: "" });
      setIsSubmitted(false);
    }, 3000);
  };

  return (
    <section id="contact" className="section bg-secondary/30">
      <div className="section-container">
        <motion.div
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          transition={{ duration: 0.5 }}
          viewport={{ once: true }}
        >
          <h2 className="section-title">Get In Touch</h2>
          <p className="section-subtitle">
            Let&apos;s work together on something great
          </p>
        </motion.div>

        <motion.div
          className="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12"
          variants={staggerContainer}
          initial="initial"
          whileInView="animate"
          viewport={{ once: true }}
        >
          {/* Contact Info Cards */}
          <motion.div
            variants={staggerItem}
            whileHover={{ scale: 1.05 }}
            className="p-6 rounded-lg glass border border-accent/20 hover:border-accent/50 smooth-transition text-center"
          >
            <Mail className="mx-auto mb-4 text-accent" size={32} />
            <h3 className="font-semibold text-text mb-2">Email</h3>
            <a
              href="mailto:yashodip@example.com"
              className="text-text-muted hover:text-accent smooth-transition"
            >
              yashodip@example.com
            </a>
          </motion.div>

          <motion.div
            variants={staggerItem}
            whileHover={{ scale: 1.05 }}
            className="p-6 rounded-lg glass border border-accent/20 hover:border-accent/50 smooth-transition text-center"
          >
            <Phone className="mx-auto mb-4 text-accent" size={32} />
            <h3 className="font-semibold text-text mb-2">Phone</h3>
            <a
              href="tel:+919876543210"
              className="text-text-muted hover:text-accent smooth-transition"
            >
              +91-9876543210
            </a>
          </motion.div>

          <motion.div
            variants={staggerItem}
            whileHover={{ scale: 1.05 }}
            className="p-6 rounded-lg glass border border-accent/20 hover:border-accent/50 smooth-transition text-center"
          >
            <MapPin className="mx-auto mb-4 text-accent" size={32} />
            <h3 className="font-semibold text-text mb-2">Location</h3>
            <p className="text-text-muted">Mumbai, India</p>
          </motion.div>
        </motion.div>

        {/* Contact Form */}
        <motion.div
          className="max-w-2xl mx-auto"
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5 }}
          viewport={{ once: true }}
        >
          <div className="p-8 rounded-lg glass border border-accent/20">
            {isSubmitted ? (
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                className="text-center py-8"
              >
                <div className="text-5xl mb-4">✓</div>
                <h3 className="text-2xl font-bold text-accent mb-2">
                  Thank you!
                </h3>
                <p className="text-text-muted">
                  I&apos;ll get back to you soon.
                </p>
              </motion.div>
            ) : (
              <form onSubmit={handleSubmit} className="space-y-6">
                <motion.div
                  initial={{ opacity: 0, x: -20 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  transition={{ delay: 0.1 }}
                  viewport={{ once: true }}
                >
                  <label className="block text-text font-semibold mb-2">
                    Name
                  </label>
                  <input
                    type="text"
                    name="name"
                    value={formData.name}
                    onChange={handleChange}
                    required
                    className="w-full px-4 py-3 rounded-lg bg-primary border border-accent/30 text-text placeholder-text-muted focus:outline-none focus:border-accent smooth-transition"
                    placeholder="Your name"
                  />
                </motion.div>

                <motion.div
                  initial={{ opacity: 0, x: -20 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  transition={{ delay: 0.2 }}
                  viewport={{ once: true }}
                >
                  <label className="block text-text font-semibold mb-2">
                    Email
                  </label>
                  <input
                    type="email"
                    name="email"
                    value={formData.email}
                    onChange={handleChange}
                    required
                    className="w-full px-4 py-3 rounded-lg bg-primary border border-accent/30 text-text placeholder-text-muted focus:outline-none focus:border-accent smooth-transition"
                    placeholder="your@email.com"
                  />
                </motion.div>

                <motion.div
                  initial={{ opacity: 0, x: -20 }}
                  whileInView={{ opacity: 1, x: 0 }}
                  transition={{ delay: 0.3 }}
                  viewport={{ once: true }}
                >
                  <label className="block text-text font-semibold mb-2">
                    Message
                  </label>
                  <textarea
                    name="message"
                    value={formData.message}
                    onChange={handleChange}
                    required
                    rows={5}
                    className="w-full px-4 py-3 rounded-lg bg-primary border border-accent/30 text-text placeholder-text-muted focus:outline-none focus:border-accent smooth-transition resize-none"
                    placeholder="Your message here..."
                  ></textarea>
                </motion.div>

                <motion.button
                  whileHover={{ scale: 1.05 }}
                  whileTap={{ scale: 0.95 }}
                  type="submit"
                  className="w-full btn-primary"
                >
                  Send Message
                </motion.button>
              </form>
            )}
          </div>
        </motion.div>
      </div>
    </section>
  );
}
